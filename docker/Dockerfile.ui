FROM python:3.11-slim

WORKDIR /app

# Install dependencies
RUN pip install --no-cache-dir \
    fastapi \
    uvicorn \
    pyspark==3.5.1 \
    grpcio \
    grpcio-status \
    pandas \
    jinja2

# Copy UI application
COPY ui/ /app/

EXPOSE 8888

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8888"]
